  <DataSets>
    <DataSet Name="SummaryData">
      <Query>
        <DataSourceName>fabric</DataSourceName>
        <CommandText>SELECT LOCATIONNAME AS RowCat, batch_month AS ColCat, SUM(signed_amount) AS Val
FROM mv_pnl_actual GROUP BY LOCATIONNAME, batch_month</CommandText>
      </Query>
      <Fields>
        <Field Name="RowCat">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>RowCat</DataField>
        </Field>
        <Field Name="ColCat">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ColCat</DataField>
        </Field>
        <Field Name="Val">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Val</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="CategoryData">
      <Query>
        <DataSourceName>fabric</DataSourceName>
        <CommandText>SELECT TOP 200
    LEFT(LOCATIONNAME,3) AS Category,
    LOCATIONNAME         AS RowCat1, 
    batch_month          AS ColCat,
    signed_amount        AS Val
FROM mv_pnl_actual</CommandText>
      </Query>
      <Fields>
        <Field Name="Category">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Category</DataField>
        </Field>
        <Field Name="RowCat1">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>RowCat1</DataField>
        </Field>
        <Field Name="ColCat">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ColCat</DataField>
        </Field>
        <Field Name="Val">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Val</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
