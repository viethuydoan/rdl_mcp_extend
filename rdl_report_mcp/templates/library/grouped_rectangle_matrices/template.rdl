  <DataSets>
    <DataSet Name="MatrixData">
      <Query>
        <DataSourceName>fabric</DataSourceName>
        <CommandText>SELECT TOP 100 LOCATIONNAME as Category, batch_month as ColCat, Level1 as RowCat1 ,Level2 as RowCat2, SUM(signed_amount) as Val1, SUM(census_denom_main) as Val2
FROM mv_pnl_actual
GROUP BY LOCATIONNAME,batch_month ,Level1 , Level2</CommandText>
      </Query>
      <Fields>
        <Field Name="Category">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Category</DataField>
        </Field>
        <Field Name="ColCat">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ColCat</DataField>
        </Field>
        <Field Name="RowCat1">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>RowCat1</DataField>
        </Field>
        <Field Name="RowCat2">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>RowCat2</DataField>
        </Field>
        <Field Name="Val1">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Val1</DataField>
        </Field>
        <Field Name="Val2">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Val2</DataField>
        </Field>
      </Fields>
    </DataSet>
